{
  "name": "mini-crm",
  "version": "0.0.1",
  "description": "Offline-first React Native mobile application for Saha CRM.",
  "private": true,
  "keywords": [
    "react-native",
    "mobile",
    "crm",
    "i18n",
    "nativewind",
    "tailwindcss"
  ],
  "scripts": {
    "android": "react-native run-android",
    "android:release": "react-native run-android --mode release",
    "android:standalone": "react-native run-android --mode standalone",
    "apk:release": "cd android && ./gradlew assembleRelease",
    "apk:standalone": "cd android && ./gradlew assembleStandalone",
    "dev": "react-native start",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "postinstall": "patch-package",
    "start": "react-native start",
    "test": "jest"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native/new-app-screen": "0.81.4",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/stack": "^7.4.8",
    "axios": "^1.12.2",
    "buffer": "^6.0.3",
    "i18next": "^25.5.1",
    "nativewind": "^4.2.1",
    "pdfmake": "^0.3.8",
    "react": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^15.2.0",
    "react-native": "0.81.4",
    "react-native-calendars": "^1.1314.0",
    "react-native-file-access": "^4.0.3",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-localize": "^3.5.1",
    "react-native-quick-sqlite": "^8.2.7",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.16.0",
    "react-native-share": "^12.2.6",
    "react-native-vector-icons": "^10.2.0",
    "tailwindcss": "^3.4.17",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.4",
    "@react-native/eslint-config": "0.81.4",
    "@react-native/metro-config": "0.81.4",
    "@react-native/typescript-config": "0.81.4",
    "@types/jest": "^29.5.13",
    "@types/pdfmake": "^0.3.3",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-preset-expo": "^54.0.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
